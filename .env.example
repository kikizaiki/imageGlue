# Application
APP_ENV=development
DEBUG=true

# KIE.ai API
KIE_API_KEY=your_kie_api_key_here
KIE_API_URL=https://api.kie.ai/v1

# Segmentation
SEGMENTATION_BACKEND=rembg
REMBG_MODEL=u2net

# Refinement
REFINEMENT_ENABLED=true
REFINEMENT_THRESHOLD=0.6

# Quality gate
QUALITY_CHECK_ENABLED=true
MIN_HEAD_SIZE_RATIO=0.02
MAX_BLUR_THRESHOLD=100.0

# Detection
DETECTION_CONFIDENCE_THRESHOLD=0.3
MIN_DOG_AREA_RATIO=0.05

# Input validation
MIN_IMAGE_WIDTH=200
MIN_IMAGE_HEIGHT=200
MAX_IMAGE_SIZE_MB=10
